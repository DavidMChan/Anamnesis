# Supabase (use service key for worker, not anon key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE=survey_tasks
RABBITMQ_PREFETCH=1

# LLM Provider: "openrouter" or "vllm"
LLM_PROVIDER=openrouter

# OpenRouter (when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=anthropic/claude-3-haiku

# vLLM (when LLM_PROVIDER=vllm)
VLLM_ENDPOINT=http://localhost:8000/v1
VLLM_MODEL=meta-llama/Llama-3-70b
VLLM_API_KEY=

# LLM Settings
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=64

# Worker Settings
MAX_RETRIES=3
RETRY_DELAY_BASE=1.0
RETRY_DELAY_MAX=30.0
