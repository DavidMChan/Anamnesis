# Supabase (use service key for worker, not anon key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE=survey_tasks
RABBITMQ_PREFETCH=1

# Wasabi (S3-compatible storage for media files)
WASABI_ACCESS_KEY_ID=your-wasabi-access-key
WASABI_SECRET_ACCESS_KEY=your-wasabi-secret-key
WASABI_BUCKET=your-bucket-name
WASABI_REGION=us-west-2
WASABI_ENDPOINT=https://s3.us-west-2.wasabisys.com

# Worker Settings
MAX_RETRIES=3
RETRY_DELAY_BASE=1.0
RETRY_DELAY_MAX=30.0
MAX_CONCURRENT_TASKS=10
METRICS_LOG_INTERVAL=30.0
